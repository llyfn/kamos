APP_ENV=local
PORT=8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://kamos_local@localhost:5432/kamos_local?sslmode=disable
JWT_SECRET=replace-with-openssl-rand-base64-48-output-32-bytes-minimum-please
# Access-token lifetime (Phase 2 default 15m, was 720h pre-refresh).
JWT_TTL=15m
# Refresh-token lifetime — long-lived but revocable, rotated on every
# /v1/auth/refresh call. SHA-256 hash stored; raw secret never persisted.
REFRESH_TTL=720h
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
INTEGRATION_DATABASE_URL=postgres://kamos_local@localhost:5432/kamos_test?sslmode=disable

# Observability — all four optional. Empty = feature OFF, no SDK init, no
# warnings. See backend/.env.example for documentation.
APP_VERSION=dev
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=

# Set to 1 to disable rate limits in local dev / stress runs. Production
# must leave this unset.
RATE_LIMIT_DISABLED=
