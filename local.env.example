APP_ENV=local
PORT=8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://kamos_local@localhost:5432/kamos_local?sslmode=disable
JWT_SECRET=replace-with-openssl-rand-base64-48-output-32-bytes-minimum-please
# Access-token lifetime (Phase 2 default 15m, was 720h pre-refresh).
JWT_TTL=15m
# Refresh-token lifetime — long-lived but revocable, rotated on every
# /v1/auth/refresh call. SHA-256 hash stored; raw secret never persisted.
REFRESH_TTL=720h
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
INTEGRATION_DATABASE_URL=postgres://kamos_local@localhost:5432/kamos_test?sslmode=disable

# Observability — all four optional. Empty = feature OFF, no SDK init, no
# warnings. See backend/.env.example for documentation.
APP_VERSION=dev
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=

# Set to 1 to disable rate limits in local dev / stress runs. Production
# must leave this unset.
RATE_LIMIT_DISABLED=

# Phase 3 — Cloudflare R2 (S3-compatible) photo storage. Empty = feature
# OFF: POST /v1/uploads/photo-presign returns 503 STORAGE_DISABLED. Fill
# both R2_ACCESS_KEY_ID *and* R2_BUCKET to enable.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Phase 3 — Resend outbound mail. Empty = feature OFF: the verification
# email is logged at INFO instead of sent. Fill both RESEND_API_KEY and
# EMAIL_FROM to enable real send.
RESEND_API_KEY=
EMAIL_FROM=

# Phase 4 — Foursquare Places API for the optional venue tag on check-ins.
# Empty = feature OFF: GET /v1/venues/search returns 503 VENUE_SEARCH_DISABLED.
# The check-in venue.foursquare_id upsert path is independent of this key
# and still works without it (clients pass already-known fsq ids).
FOURSQUARE_API_KEY=

# Stage 0 — Security hardening (SEC-002, SEC-005, SEC-007).
# CURSOR_SECRET signs keyset pagination cursors; must be ≥ 32 bytes in
# production. In dev the loader derives one from JWT_SECRET if unset.
CURSOR_SECRET=
# CORS allowlist for the admin client. Dev default = http://localhost:5173.
CORS_ALLOWED_ORIGINS=
# Set FORCE_HSTS=1 only when running behind a TLS terminator that does
# not forward X-Forwarded-Proto.
FORCE_HSTS=

# --- dev (Fly.io) sample values ---------------------------------------------
# These are not loaded by the local server (they're commented out). They
# document the shape of values the operator sets via `flyctl secrets set`
# on the kamos-dev app. See docs/runbooks/staging-deploy.md.
#
# APP_ENV=staging
# APP_VERSION=<git-sha-set-per-deploy>
# DATABASE_URL=postgres://<user>:<pass>@<host>:5432/kamos?sslmode=require
# APP_BASE_URL=https://dev-api.kamos.app
# CORS_ALLOWED_ORIGINS=https://dev-admin.kamos.app
# CACHE_BACKEND=redis
# CACHE_REDIS_URL=rediss://<user>:<pass>@<upstash-host>:6379
# R2_PUBLIC_BASE_URL=https://photos-dev.kamos.app

