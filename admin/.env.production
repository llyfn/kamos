# Production build configuration for the admin SPA.
# Vite reads this in production mode (`vite build`); deploy-admin.yml builds
# here in CI, so the value below is baked into dist/ and uploaded to
# Cloudflare Pages via Wrangler. No dashboard env var needed.
#
# Empty = same-origin. The SPA calls relative /v1/* on kamos-admin.pages.dev,
# which the Pages Function at functions/v1/[[path]].ts proxies to the Fly API.
# This keeps the admin's SameSite=Strict cookies first-party (see that file).
VITE_API_BASE_URL=
