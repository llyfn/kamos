# KAMOS — backend environment variables.
# Copy to `.env` and fill in. Do NOT commit `.env`.

# HTTP server port.
PORT=8080

# Operating mode: "dev" enables verbose logging in the future.
APP_ENV=dev

# Base URL used in verification-email links (no trailing slash).
APP_BASE_URL=http://localhost:3000

# PostgreSQL connection string. Use sslmode=disable for local dev only.
DATABASE_URL=postgres://kamos:kamos@localhost:5432/kamos?sslmode=disable

# JWT signing secret. Must be ≥ 32 random bytes in production.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-a-real-secret-of-at-least-32-bytes

# Access-token (JWT) lifetime. Phase 2 default 15m — short-lived; rotated
# via /v1/auth/refresh. Pre-refresh default was 720h.
JWT_TTL=15m

# Refresh-token lifetime. Long-lived but revocable; rotated on every call
# to /v1/auth/refresh. Server stores SHA-256 hash only, never the raw
# secret.
REFRESH_TTL=720h

# Google OAuth — only the CLIENT ID is needed server-side. The API verifies
# ID tokens by audience match against this client ID; no client secret is
# required for that flow. The client secret stays out of the codebase
# entirely. CONFIGURE: leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# SMTP for verification email. CONFIGURE: wire to your provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# Observability — all four are OPTIONAL. Leave blank and the corresponding
# feature is fully disabled at boot (no SDK init, no warnings, no degraded
# behavior). Wire these up only after you've signed up for the vendor.
# ---------------------------------------------------------------------------

# Reported as service.version on every OTel span and as the Sentry release tag.
# Bump per deploy; "dev" is the unbuilt-local fallback.
APP_VERSION=dev

# OTLP HTTP exporter for traces + metrics. Grafana Cloud / OpenTelemetry
# Collector / Honeycomb all accept the host[:port] form. Empty = OTel OFF.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Comma-separated "k1=v1,k2=v2" headers — usually one Authorization line.
OTEL_EXPORTER_OTLP_HEADERS=

# Sentry DSN. Empty = Sentry OFF. We disable Sentry's tracing because OTel
# above already ships spans; Sentry only catches panics here.
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Rate-limit override.
#
# Production defaults are documented in DEPLOYMENT.md §3:
#   * 30 rps / burst 60 — global per-IP
#   * 5 rps / burst 10  — per-IP on /v1/auth/*
#   * 60 rps / burst 120 — per-user on authed routes
#
# Set RATE_LIMIT_DISABLED=1 ONLY for local stress runs or unusual tooling.
# Production MUST leave this unset.
# ---------------------------------------------------------------------------
RATE_LIMIT_DISABLED=

# ---------------------------------------------------------------------------
# Phase 3 — Blob storage (Cloudflare R2, S3-compatible).
#
# Leave R2_BUCKET (or R2_ACCESS_KEY_ID) empty to disable the photo-upload
# feature. POST /v1/uploads/photo-presign returns 503 STORAGE_DISABLED in
# that case. The orphan-cleanup job no-ops the Delete call so nothing crashes.
#
# R2_PUBLIC_BASE_URL is the CDN / custom domain URL the mobile client uses
# to FETCH photos (e.g., https://photos.kamos.app or the bucket's r2.dev
# subdomain). The presigned URL is for PUT; this base URL is for GET.
# ---------------------------------------------------------------------------
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# Phase 3 — Outbound mail (Resend).
#
# Empty RESEND_API_KEY or EMAIL_FROM falls back to LogMailer: the
# verification email is logged at INFO instead of sent. This keeps dev
# workflow intact (copy the link out of the API log).
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=
