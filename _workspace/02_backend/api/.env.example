# KAMOS — backend environment variables.
# Copy to `.env` and fill in. Do NOT commit `.env`.

# HTTP server port.
PORT=8080

# Operating mode: "dev" enables verbose logging in the future.
APP_ENV=dev

# Base URL used in verification-email links (no trailing slash).
APP_BASE_URL=http://localhost:3000

# PostgreSQL connection string. Use sslmode=disable for local dev only.
DATABASE_URL=postgres://kamos:kamos@localhost:5432/kamos?sslmode=disable

# JWT signing secret. Must be ≥ 32 random bytes in production.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-a-real-secret-of-at-least-32-bytes

# JWT lifetime. SPEC §3.1 deferral: long-lived for MVP, refresh deferred to v1.1.
JWT_TTL=720h

# Google OAuth — only the CLIENT ID is needed server-side. The API verifies
# ID tokens by audience match against this client ID; no client secret is
# required for that flow. The client secret stays out of the codebase
# entirely. CONFIGURE: leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# SMTP for verification email. CONFIGURE: wire to your provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
