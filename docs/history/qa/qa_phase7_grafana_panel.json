{
  "id": null,
  "type": "timeseries",
  "title": "Cache hit-rate by name",
  "description": "Per-cache hit ratio over a 5-minute rolling window. Fed by cache_requests_total{cache,outcome=hit|miss} emitted by internal/cache + internal/observability/prom.go. Cardinality is bounded by the names registered in cache.NewCaches: categories, flavor_tags, beverage_detail, brewery_detail. Empty series before any traffic is normal — Prom only emits a label set once it has been incremented.",
  "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "expr": "sum by (cache) (rate(cache_requests_total{outcome=\"hit\"}[5m])) / sum by (cache) (rate(cache_requests_total[5m]))",
      "legendFormat": "{{cache}}",
      "range": true,
      "instant": false,
      "editorMode": "code"
    }
  ],
  "options": {
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    },
    "legend": {
      "displayMode": "table",
      "placement": "bottom",
      "showLegend": true,
      "calcs": ["lastNotNull", "mean"]
    }
  },
  "fieldConfig": {
    "defaults": {
      "unit": "percentunit",
      "min": 0,
      "max": 1,
      "decimals": 2,
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "red", "value": null },
          { "color": "orange", "value": 0.5 },
          { "color": "green", "value": 0.8 }
        ]
      },
      "color": {
        "mode": "palette-classic"
      },
      "custom": {
        "drawStyle": "line",
        "lineInterpolation": "smooth",
        "lineWidth": 2,
        "fillOpacity": 10,
        "spanNulls": false,
        "showPoints": "never",
        "axisPlacement": "auto",
        "axisLabel": "hit rate"
      }
    },
    "overrides": []
  },
  "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 0
  },
  "pluginVersion": "11.0.0"
}
