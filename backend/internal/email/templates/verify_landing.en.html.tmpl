<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.AppName}} — Email verification</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif; color: #1c1c1e; background: #fafafa; margin: 0; padding: 24px;">
  <div style="max-width: 480px; margin: 48px auto; background: #ffffff; border-radius: 12px; padding: 32px; text-align: center;">
    <p style="margin: 0 0 12px; font-size: 13px; letter-spacing: 0.1em; color: #8a8a8a; text-transform: uppercase;">{{.AppName}}</p>
    {{if eq .Status "Verified"}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">Email verified</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">Open {{.AppName}} to continue.</p>
    {{else if eq .Status "AlreadyVerified"}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">Already verified</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">Your email is already confirmed. Open {{.AppName}} to continue.</p>
    {{else}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">Verification link invalid or expired</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">Request a new verification link from the {{.AppName}} app.</p>
    {{end}}
  </div>
</body>
</html>
