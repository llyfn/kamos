<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.AppName}} — メールアドレスの確認</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, Hiragino Sans, Yu Gothic, sans-serif; color: #1c1c1e; background: #fafafa; margin: 0; padding: 24px;">
  <div style="max-width: 480px; margin: 48px auto; background: #ffffff; border-radius: 12px; padding: 32px; text-align: center;">
    <p style="margin: 0 0 12px; font-size: 13px; letter-spacing: 0.1em; color: #8a8a8a; text-transform: uppercase;">{{.AppName}}</p>
    {{if eq .Status "Verified"}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">メールアドレスを確認しました</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">{{.AppName}} アプリを開いて続けてください。</p>
    {{else if eq .Status "AlreadyVerified"}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">確認済みです</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">このメールアドレスはすでに確認されています。{{.AppName}} アプリを開いて続けてください。</p>
    {{else}}
      <h1 style="margin: 0 0 16px; font-size: 22px;">リンクが無効または期限切れです</h1>
      <p style="margin: 0 0 8px; color: #4a4a4a;">{{.AppName}} アプリから新しい確認リンクをリクエストしてください。</p>
    {{end}}
  </div>
</body>
</html>
